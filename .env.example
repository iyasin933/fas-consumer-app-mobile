# Copy to `.env` in this folder (same level as app.json). Restart Expo after changes.

EXPO_PUBLIC_API_URL=https://api.dropyou.co.uk/api/v1
# Required for sign-up role id (numeric CONSUMER role in your DB)
EXPO_PUBLIC_CONSUMER_ROLE_ID=

# Google Sign-In — create OAuth clients in Google Cloud Console, then:
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google Maps — JS runtime key (Places Autocomplete + Geocoding HTTP APIs).
# Enable in Google Cloud Console: Places API + Geocoding API.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Maps — NATIVE keys, consumed by app.config.js at prebuild/build time.
# Android is REQUIRED for Google Maps tiles (Maps SDK for Android).
# iOS is OPTIONAL — only needed if you set PROVIDER_GOOGLE on iOS (we default
# to Apple Maps, which needs no key). Enable: Maps SDK for iOS if you do.
GOOGLE_MAPS_ANDROID_API_KEY=
GOOGLE_MAPS_IOS_API_KEY=

# Stripe — Payment Sheet / `@stripe/stripe-react-native` (publishable key only).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Create-intent `amount` is sent in major units (pounds) by default; backend converts for Stripe.
# Set false only if your API expects pence/cents in the request body:
# EXPO_PUBLIC_PAYMENT_CREATE_INTENT_AMOUNT_MAJOR=false

# Socket.IO — same host as API is common; omit `/api/v1` and no trailing `/`
# (e.g. `https://api.dropyou.co.uk`). Default Engine path is `/socket.io`; override if needed:
# EXPO_PUBLIC_SOCKET_PATH=/socket.io
# Load quotes: `subscribe_to_load` / `dropyou_quote_received` (see LoadQuotesSocketProvider).
EXPO_PUBLIC_SOCKET_URL=
