{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "Maps display labels to src/lib/utils/assets.ts keys and paths under assets/images/. Paths match require() in assets.ts.",
  "homeScreen": {
    "heroIllustration": {
      "name": "Driver illustration (Start your delivery card)",
      "assetKey": null,
      "importPath": "assets/images/driverImage.svg",
      "usage": "Home: delivery promo card art (DriverImage component)",
      "type": "svg"
    },
    "locationFrameArt": {
      "name": "Location connection frame",
      "assetKey": null,
      "importPath": "assets/images/locationFrame.svg",
      "usage": "Ongoing booking cards route visual",
      "type": "svg"
    }
  },
  "transportAndServiceIcons": [
    {
      "id": "car_hire",
      "displayName": "Car Hire",
      "assetKey": "riderCar",
      "fileName": "rider-car.png",
