{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "$EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "GOOGLE_MAPS_IOS_API_KEY": "$GOOGLE_MAPS_IOS_API_KEY",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "resourceClass": "m-medium", "image": "latest" },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "$EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "GOOGLE_MAPS_IOS_API_KEY": "$GOOGLE_MAPS_IOS_API_KEY",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY"
      }
    },
    "production": {
      "channel": "production",
      "ios": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "$EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "GOOGLE_MAPS_IOS_API_KEY": "$GOOGLE_MAPS_IOS_API_KEY",
        "GOOGLE_MAPS_ANDROID_API_KEY": "$GOOGLE_MAPS_ANDROID_API_KEY"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
